{
  "name": "@rexymayderio/html-pdf-forge",
  "version": "1.4.0",
  "description": "Generate PDFs from HTML with a clean TypeScript API. Wraps html-to-pdfmake + pdfmake into a single, ergonomic surface.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./merge": {
      "types": "./dist/merge.d.ts",
      "import": "./dist/merge.js",
      "require": "./dist/merge.js"
    },
    "./split": {
      "types": "./dist/split.d.ts",
      "import": "./dist/split.js",
      "require": "./dist/split.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "npm run build && changeset publish",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "pdf",
    "html",
    "html-to-pdf",
    "pdfmake",
    "html-to-pdfmake",
    "pdf-generation",
    "watermark",
    "qr-code",
    "barcode",
    "pdf-merge",
    "pdf-split"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RexySaragih/html-pdf-forge.git"
  },
  "bugs": {
    "url": "https://github.com/RexySaragih/html-pdf-forge/issues"
  },
  "homepage": "https://github.com/RexySaragih/html-pdf-forge#readme",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bwip-js": "^4.5.1",
    "html-to-pdfmake": "^2.5.18",
    "jsdom": "^24.1.0",
    "mustache": "^4.2.0",
    "pdf-lib": "^1.17.1",
    "pdfmake": "^0.2.10",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/jsdom": "^21.1.7",
    "@types/mustache": "^4.2.5",
    "@types/node": "^20.14.0",
    "@types/pdfmake": "^0.2.9",
    "@types/qrcode": "^1.5.5",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.61.0",
    "vitest": "^2.0.5"
  }
}
