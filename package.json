{
  "name": "html-pdf-forge",
  "version": "0.1.0",
  "description": "Generate PDFs from HTML with a clean TypeScript API. Wraps html-to-pdfmake + pdfmake into a single, ergonomic surface.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "pdf",
    "html",
    "html-to-pdf",
    "pdfmake",
    "html-to-pdfmake",
    "pdf-generation"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "html-to-pdfmake": "^2.5.18",
    "jsdom": "^24.1.0",
    "mustache": "^4.2.0",
    "pdfmake": "^0.2.10"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/mustache": "^4.2.5",
    "@types/node": "^20.14.0",
    "@types/pdfmake": "^0.2.9",
    "typescript": "^5.5.4"
  }
}
